{
  "schemaVersion": 1,
  "plugin": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./credentials.json)",
      "Read(./credentials.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)"
    ],
    "gitGuard": {
      "protectedBranches": ["main", "master"],
      "dangerousOps": {
        "forcePush": true,
        "resetHard": true,
        "restore": true,
        "clean": true,
        "checkoutDiscard": true
      },
      "override": {
        "env": "AEGIS_ALLOW_GIT_GUARD",
        "marker": "# aegis:allow-git"
      }
    }
  },
  "defaults": {
    "bucket": "RO",
    "claude": {
      "tools": ["Read", "Grep", "Glob"]
    },
    "opencode": {
      "*": "deny",
      "read": "allow",
      "grep": "allow",
      "glob": "allow",
      "list": "allow"
    }
  },
  "agents": {
    "code-explorer": {
      "bucket": "RO",
      "claude": {
        "tools": ["Read", "Grep", "Glob"],
        "model": "haiku",
        "disallowedTools": ["Edit", "Write"]
      },
      "opencode": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "deny",
        "write": "deny"
      },
      "justification": "Maps call chains with file:line evidence; no writes."
    },
    "code-quality-reviewer": {
      "bucket": "RO",
      "claude": {
        "tools": ["Read", "Grep", "Glob"],
        "model": "sonnet",
        "disallowedTools": ["Edit", "Write"]
      },
      "opencode": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "deny",
        "write": "deny"
      },
      "justification": "Stage 2 reviewer; hard read-only per body.",
      "prose": "Your only tools are Read, Glob, and Grep. You do not write, edit, or execute anything."
    },
    "spec-reviewer": {
      "bucket": "RO",
      "claude": {
        "tools": ["Read", "Grep", "Glob"],
        "model": "sonnet",
        "disallowedTools": ["Edit", "Write"]
      },
      "opencode": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "deny",
        "write": "deny"
      },
      "justification": "Stage 1 reviewer; hard read-only per body.",
      "prose": "Your only tools are Read, Glob, and Grep. You do not write, edit, or execute anything."
    },
    "silent-failure-hunter": {
      "bucket": "RO",
      "claude": {
        "tools": ["Read", "Grep", "Glob"],
        "model": "sonnet",
        "disallowedTools": ["Edit", "Write"]
      },
      "opencode": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "deny",
        "write": "deny"
      },
      "justification": "Error-handling auditor; reports findings, never modifies code.",
      "prose": "Read-only. Report findings. Never modify code."
    },
    "code-reviewer": {
      "bucket": "RO",
      "claude": {
        "tools": ["Read", "Grep", "Glob"],
        "model": "opus",
        "disallowedTools": ["Edit", "Write"]
      },
      "opencode": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "deny",
        "write": "deny"
      },
      "justification": "Two-pass reviewer; read-only itself per body.",
      "prose": "Read-only — Read/Glob/Grep, no shell."
    },
    "plan-verifier": {
      "bucket": "RO",
      "claude": {
        "tools": ["Read", "Grep", "Glob"],
        "model": "sonnet",
        "disallowedTools": ["Edit", "Write"]
      },
      "opencode": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "deny",
        "write": "deny"
      },
      "justification": "Plan gatekeeper; does not execute, improve, or rewrite plans."
    },
    "code-architect": {
      "bucket": "RO",
      "claude": {
        "tools": ["Read", "Grep", "Glob"],
        "model": "opus",
        "disallowedTools": ["Edit", "Write"]
      },
      "opencode": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "deny",
        "write": "deny"
      },
      "justification": "Proposes approaches; designs only, does not implement.",
      "prose": "Read-only. Tools: Read, Grep, Glob. You produce designs, not code."
    },
    "test-analyzer": {
      "bucket": "RO-bash",
      "claude": {
        "tools": [
          "Read",
          "Grep",
          "Glob",
          "Bash(npm test*)",
          "Bash(bun test*)",
          "Bash(pnpm test*)",
          "Bash(node *)",
          "Bash(tsc *)",
          "Bash(go test*)",
          "Bash(cargo test*)",
          "Bash(pytest*)"
        ],
        "model": "sonnet",
        "disallowedTools": ["Edit", "Write"]
      },
      "opencode": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "npm test*": "allow",
          "bun test*": "allow",
          "pnpm test*": "allow",
          "node *": "allow",
          "tsc *": "allow",
          "go test*": "allow",
          "cargo test*": "allow",
          "pytest*": "allow"
        }
      },
      "justification": "Coverage analysis may run tests to confirm gaps; Bash scoped to test runners only."
    },
    "doc-verifier": {
      "bucket": "RO-bash",
      "claude": {
        "tools": [
          "Read",
          "Grep",
          "Glob",
          "Bash(npm test*)",
          "Bash(bun test*)",
          "Bash(pnpm test*)",
          "Bash(node *)",
          "Bash(tsc *)",
          "Bash(go test*)",
          "Bash(cargo test*)",
          "Bash(pytest*)"
        ],
        "model": "sonnet",
        "disallowedTools": ["Edit", "Write"]
      },
      "opencode": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "npm test*": "allow",
          "bun test*": "allow",
          "pnpm test*": "allow",
          "node *": "allow",
          "tsc *": "allow",
          "go test*": "allow",
          "cargo test*": "allow",
          "pytest*": "allow"
        }
      },
      "justification": "Verifies code examples compile/run; Bash scoped to compile/run, no Edit/Write."
    },
    "researcher": {
      "bucket": "RO-web",
      "claude": {
        "tools": ["Read", "Grep", "Glob", "WebFetch", "WebSearch"],
        "model": "sonnet",
        "disallowedTools": ["Edit", "Write"]
      },
      "opencode": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "edit": "deny",
        "write": "deny"
      },
      "justification": "Researches and reports; no implementation. Web access for sources; caller saves the report (Open Question 1: default RO-web, no Write).",
      "prose": "You do not implement anything. You research, synthesize, and report."
    },
    "framework-selector": {
      "bucket": "RO-web",
      "claude": {
        "tools": ["Read", "Grep", "Glob", "WebFetch", "WebSearch"],
        "model": "sonnet",
        "disallowedTools": ["Edit", "Write"]
      },
      "opencode": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "edit": "deny",
        "write": "deny"
      },
      "justification": "Evaluates, scores, and recommends; no implementation. Web access for framework research; caller saves the matrix (Open Question 1).",
      "prose": "You evaluate and recommend; you don't implement."
    },
    "code-simplifier": {
      "bucket": "RW",
      "claude": {
        "tools": ["Read", "Edit", "Grep", "Glob"],
        "model": "sonnet"
      },
      "opencode": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "allow"
      },
      "justification": "Simplifies code in place; needs Edit. Must not change behaviour, no Bash needed."
    },
    "build-error-resolver": {
      "bucket": "RW-bash",
      "claude": {
        "tools": [
          "Read",
          "Edit",
          "Grep",
          "Glob",
          "Bash(npm *)",
          "Bash(bun *)",
          "Bash(pnpm *)",
          "Bash(node *)",
          "Bash(tsc *)",
          "Bash(go build*)",
          "Bash(go vet*)",
          "Bash(cargo check*)",
          "Bash(cargo build*)"
        ],
        "model": "sonnet"
      },
      "opencode": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "allow",
        "bash": {
          "*": "deny",
          "npm *": "allow",
          "bun *": "allow",
          "pnpm *": "allow",
          "node *": "allow",
          "tsc *": "allow",
          "go build*": "allow",
          "go vet*": "allow",
          "cargo check*": "allow",
          "cargo build*": "allow"
        }
      },
      "justification": "Runs build/typecheck, applies minimal fix, re-runs build; needs Edit + Bash scoped to build commands."
    },
    "mcp-builder": {
      "bucket": "Full",
      "claude": {
        "tools": ["Read", "Edit", "Write", "Grep", "Glob", "Bash", "mcp__*"],
        "model": "opus"
      },
      "opencode": {
        "*": "allow",
        "bash": "ask"
      },
      "justification": "Scaffolds (Write), implements TDD (Edit), runs tests (Bash); heaviest non-orchestrator agent. mcp__* wildcard (Open Question 2: tighten in v0.0.6)."
    },
    "orchestrator": {
      "bucket": "Task-only",
      "claude": {
        "tools": ["Read", "Grep", "Glob", "Task"],
        "model": "sonnet"
      },
      "opencode": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "task": "allow"
      },
      "justification": "Fans out parallel waves and dispatches subagents; does not implement. No Edit/Write/Bash."
    },
    "subagent-executor": {
      "bucket": "Full+Task",
      "claude": {
        "tools": ["Read", "Edit", "Write", "Grep", "Glob", "Bash", "Task"],
        "model": "sonnet"
      },
      "opencode": {
        "*": "allow",
        "bash": "ask",
        "task": "allow"
      },
      "justification": "Dispatches implementers and runs review gates; needs Task. Can patch trivial issues itself."
    },
    "ultra-worker": {
      "bucket": "Full+Task+Web",
      "claude": {
        "tools": [
          "Read",
          "Edit",
          "Write",
          "Grep",
          "Glob",
          "Bash",
          "Task",
          "WebFetch",
          "WebSearch"
        ],
        "model": "opus"
      },
      "opencode": {
        "*": "allow",
        "doom_loop": "allow"
      },
      "justification": "Autonomous plan-execute-verify loop; broadest scope by design. Highest privilege with documented escalation path."
    }
  }
}
