{
  "name": "aegis",
  "displayName": "Aegis",
  "version": "0.2.1",
  "description": "Plugin-first agentic AI development system. Skills, agents, commands, rules, and templates for software development tasks.",
  "author": {
    "name": "Aegis Contributors"
  },
  "license": "MIT",
  "keywords": [
    "agentic",
    "skills",
    "agents",
    "development",
    "anvil"
  ],
  "skills": [
    "./adapters/claude/skills/core/"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/.claude-plugin/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/.claude-plugin/hooks/pre-compact.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/.claude-plugin/hooks/post-compact.sh"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/.claude-plugin/hooks/instructions-loaded.sh"
          }
        ]
      }
    ]
  },
  "agents": [
    "./adapters/claude/agents/build-error-resolver.md",
    "./adapters/claude/agents/code-architect.md",
    "./adapters/claude/agents/code-explorer.md",
    "./adapters/claude/agents/code-quality-reviewer.md",
    "./adapters/claude/agents/code-reviewer.md",
    "./adapters/claude/agents/code-simplifier.md",
    "./adapters/claude/agents/doc-verifier.md",
    "./adapters/claude/agents/framework-selector.md",
    "./adapters/claude/agents/mcp-builder.md",
    "./adapters/claude/agents/orchestrator.md",
    "./adapters/claude/agents/plan-verifier.md",
    "./adapters/claude/agents/researcher.md",
    "./adapters/claude/agents/silent-failure-hunter.md",
    "./adapters/claude/agents/spec-reviewer.md",
    "./adapters/claude/agents/subagent-executor.md",
    "./adapters/claude/agents/test-analyzer.md",
    "./adapters/claude/agents/ultra-worker.md"
  ],
  "userConfig": {
    "preferredLanguageOverlay": {
      "type": "string",
      "title": "Preferred language overlay",
      "description": "Default language practice fragment for the develop skill to bias toward (e.g. python). Empty for none.",
      "default": ""
    },
    "telemetryOptIn": {
      "type": "boolean",
      "title": "Telemetry opt-in",
      "description": "Allow Aegis to collect anonymous usage telemetry.",
      "default": false
    }
  },
  "dependencies": [],
  "commands": [
    "./adapters/claude/commands/pr.md",
    "./adapters/claude/commands/skill.md",
    "./adapters/claude/commands/skill-pin.md",
    "./adapters/claude/commands/skill-search.md",
    "./adapters/claude/commands/skill-unpin.md",
    "./adapters/claude/commands/statusline.md"
  ]
}
